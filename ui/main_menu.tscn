[gd_scene format=3]

[ext_resource type="Script" path="res://ui/main_menu.gd" id="menu_script"]
[ext_resource type="Resource" path="res://track/layouts/starter_chicane_loop.tres" id="starter_chicane_layout"]
[ext_resource type="Resource" path="res://track/layouts/starter_dogleg_sprint.tres" id="starter_dogleg_layout"]
[ext_resource type="Resource" path="res://track/layouts/starter_figure_eight.tres" id="starter_figure_eight_layout"]
[ext_resource type="Resource" path="res://track/layouts/starter_octagon_loop.tres" id="starter_octagon_layout"]
[ext_resource type="Resource" path="res://track/layouts/starter_offset_loop.tres" id="starter_offset_layout"]
[ext_resource type="Resource" path="res://track/layouts/starter_rectangle_loop.tres" id="starter_rectangle_layout"]
[ext_resource type="Script" path="res://track/track_layout.gd" id="track_layout_script"]
[ext_resource type="Script" path="res://track/test_track.gd" id="track_script"]

[sub_resource type="Environment" id="env"]
background_mode = 1
background_color = Color(0.4, 0.5, 0.6, 1)
ambient_light_source = 2
ambient_light_color = Color(0.55, 0.55, 0.6, 1)
ambient_light_energy = 0.8
tonemap_mode = 2

[sub_resource type="StyleBoxFlat" id="start_panel_style"]
bg_color = Color(0.12, 0.14, 0.18, 0.94)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(1, 0.92, 0.65, 0.35)
corner_radius_top_left = 18
corner_radius_top_right = 18
corner_radius_bottom_right = 18
corner_radius_bottom_left = 18

[node name="MainMenu" type="Node3D"]
script = ExtResource("menu_script")
track_path = NodePath("Track")
camera_path = NodePath("MenuCamera")
track_row_path = NodePath("MenuUI/Center/VBox/TrackRow")
mute_button_path = NodePath("MenuUI/MuteButton")
choose_car_button_path = NodePath("MenuUI/Center/VBox/ChooseCarButton")
car_selection_label_path = NodePath("MenuUI/Center/VBox/CarSelectionLabel")

[node name="WorldEnv" type="WorldEnvironment" parent="."]
environment = SubResource("env")

[node name="Sun" type="DirectionalLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.5, -0.866, 0, 0.866, 0.5, 0, 20, 0)
shadow_enabled = true

[node name="MenuCamera" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 90, 0)
current = true

[node name="Track" type="Node3D" parent="."]
script = ExtResource("track_script")
starter_layouts = Array[ExtResource("track_layout_script")]([ExtResource("starter_rectangle_layout"), ExtResource("starter_chicane_layout"), ExtResource("starter_offset_layout"), ExtResource("starter_dogleg_layout"), ExtResource("starter_octagon_layout"), ExtResource("starter_figure_eight_layout")])
active_starter_layout_index = 5

[node name="MenuUI" type="CanvasLayer" parent="."]
layer = 2

[node name="Vignette" type="ColorRect" parent="MenuUI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.03, 0.04, 0.06, 0.55)
mouse_filter = 2

[node name="Center" type="CenterContainer" parent="MenuUI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="VBox" type="VBoxContainer" parent="MenuUI/Center"]
theme_override_constants/separation = 24

[node name="TitleLabel" type="Label" parent="MenuUI/Center/VBox"]
theme_override_font_sizes/font_size = 96
theme_override_colors/font_color = Color(1, 0.95, 0.82, 1)
theme_override_colors/font_outline_color = Color(0.05, 0.06, 0.1, 0.95)
theme_override_constants/outline_size = 10
horizontal_alignment = 1
text = "overlap"

[node name="StartPanel" type="PanelContainer" parent="MenuUI/Center/VBox"]
custom_minimum_size = Vector2(320, 0)
mouse_filter = 2
theme_override_styles/panel = SubResource("start_panel_style")

[node name="Margin" type="MarginContainer" parent="MenuUI/Center/VBox/StartPanel"]
theme_override_constants/margin_left = 48
theme_override_constants/margin_top = 22
theme_override_constants/margin_right = 48
theme_override_constants/margin_bottom = 22

[node name="StartLabel" type="Label" parent="MenuUI/Center/VBox/StartPanel/Margin"]
theme_override_font_sizes/font_size = 40
theme_override_colors/font_color = Color(0.95, 0.97, 1, 1)
horizontal_alignment = 1
text = "Start"

[node name="TrackRow" type="HBoxContainer" parent="MenuUI/Center/VBox"]
alignment = 1
theme_override_constants/separation = 14

[node name="TrackButton1" type="Button" parent="MenuUI/Center/VBox/TrackRow"]
custom_minimum_size = Vector2(54, 54)
theme_override_font_sizes/font_size = 24
text = "1"

[node name="TrackButton2" type="Button" parent="MenuUI/Center/VBox/TrackRow"]
custom_minimum_size = Vector2(54, 54)
theme_override_font_sizes/font_size = 24
text = "2"

[node name="TrackButton3" type="Button" parent="MenuUI/Center/VBox/TrackRow"]
custom_minimum_size = Vector2(54, 54)
theme_override_font_sizes/font_size = 24
text = "3"

[node name="TrackButton4" type="Button" parent="MenuUI/Center/VBox/TrackRow"]
custom_minimum_size = Vector2(54, 54)
theme_override_font_sizes/font_size = 24
text = "4"

[node name="TrackButton5" type="Button" parent="MenuUI/Center/VBox/TrackRow"]
custom_minimum_size = Vector2(54, 54)
theme_override_font_sizes/font_size = 24
text = "5"

[node name="TrackButton6" type="Button" parent="MenuUI/Center/VBox/TrackRow"]
custom_minimum_size = Vector2(54, 54)
theme_override_font_sizes/font_size = 24
text = "8"

[node name="ChooseCarButton" type="Button" parent="MenuUI/Center/VBox"]
custom_minimum_size = Vector2(320, 44)
theme_override_font_sizes/font_size = 20
text = "Choose your car"

[node name="CarSelectionLabel" type="Label" parent="MenuUI/Center/VBox"]
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(1, 0.92, 0.65, 0.95)
horizontal_alignment = 1
text = "Currently: Sunset Coupe"

[node name="HintLabel" type="Label" parent="MenuUI/Center/VBox"]
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.82, 0.88, 0.94, 0.85)
horizontal_alignment = 1
text = "press any key or click to start"

[node name="MuteButton" type="Button" parent="MenuUI"]
anchor_top = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = -60.0
offset_right = 160.0
offset_bottom = -20.0
focus_mode = 0
theme_override_font_sizes/font_size = 18
text = "Sound Off"
